<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:paddingLeft="24dp"
    android:paddingRight="24dp"
    android:paddingTop="48dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/tvRecurringTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thanh Toán Định Kỳ"
        android:textColor="@color/app_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnOpenAddRecurringDialog"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="+ Thêm Tiền Hàng Tháng"
        android:textColor="@color/app_button_text"
        android:backgroundTint="@color/app_accent_income"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvRecurringTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvRecurringListLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Danh Sách Các Khoản Định Kỳ"
        android:textColor="@color/app_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnOpenAddRecurringDialog"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Scrollable list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvRecurringListLabel"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/layoutRecurringContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
