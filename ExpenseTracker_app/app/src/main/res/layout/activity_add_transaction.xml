<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E2C"
    android:paddingLeft="24dp"
    android:paddingRight="24dp"
    android:paddingTop="48dp"
    android:paddingBottom="24dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ghi chép giao dịch"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Smart OCR Scanner Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardOcr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#2A1B3D"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📸 Quét Hóa Đơn AI (OCR)"
                        android:textColor="#00FF66"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chụp/chọn ảnh hóa đơn để tự điền nhanh thông tin"
                        android:textColor="#A0A0B0"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:gravity="center" />

                    <Button
                        android:id="@+id/btnOcrScan"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Bắt đầu quét"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#00FF66"
                        android:layout_marginTop="12dp"
                        android:textSize="12sp" />

                    <ProgressBar
                        android:id="@+id/ocrProgressBar"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:visibility="gone"
                        android:layout_marginTop="8dp"
                        android:indeterminateTint="#00FF66" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoặc nhập thủ công"
                android:textColor="#8A8A9E"
                android:textSize="12sp"
                android:layout_marginTop="20dp" />

            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#2A2A3E"
                android:hint="Số tiền (đ)"
                android:textColorHint="#808090"
                android:textColor="#FFFFFF"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="number"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#2A2A3E"
                android:hint="Ghi chú / Mô tả"
                android:textColorHint="#808090"
                android:textColor="#FFFFFF"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="text"
                android:layout_marginTop="12dp" />

            <Spinner
                android:id="@+id/spinnerType"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#2A2A3E"
                android:layout_marginTop="12dp"
                android:padding="8dp" />

            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#2A2A3E"
                android:layout_marginTop="12dp"
                android:padding="8dp" />

            <Spinner
                android:id="@+id/spinnerWallet"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#2A2A3E"
                android:layout_marginTop="12dp"
                android:padding="8dp" />

            <Button
                android:id="@+id/btnSaveTransaction"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Lưu giao dịch"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00FF66"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="40dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
