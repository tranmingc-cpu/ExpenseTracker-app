<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 AI Smart Budget Planner"
            android:textColor="@color/app_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardHealth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/app_surface"
            app:layout_constraintTop_toBottomOf="@id/tvTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sức Khỏe Tài Chính"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tvHealthScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="85"
                        android:textColor="@color/app_accent_income"
                        android:textSize="48sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvHealthStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/tvHealthScore"
                        android:layout_marginStart="12dp"
                        android:layout_alignTop="@id/tvHealthScore"
                        android:text="Xuất sắc"
                        android:textColor="@color/app_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/tvHealthScore"
                        android:layout_marginStart="12dp"
                        android:layout_below="@id/tvHealthStatus"
                        android:text="Dựa trên tỷ lệ tiết kiệm &amp; ngân sách"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="12sp"/>

                </RelativeLayout>

                <ProgressBar
                    android:id="@+id/pbHealth"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="16dp"
                    android:progress="85"
                    android:progressTint="@color/app_accent_income"
                    android:progressBackgroundTint="@color/app_divider"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardForecast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/app_surface"
            app:layout_constraintTop_toBottomOf="@id/cardHealth">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Rủi ro chi tiêu vượt mức:"
                        android:textColor="@color/app_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvRiskStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THẤP"
                        android:textColor="@color/app_accent_income"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="#153D2A"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/app_divider"
                    android:layout_marginVertical="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dự Báo Chi Tiêu Tháng"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Hiện tại:"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvCurrentSpent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textColor="@color/app_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Dự báo cuối tháng:"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvPredictedSpent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textColor="@color/app_accent_warning"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Còn lại:"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvRemainingBudget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textColor="@color/app_accent_income"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Savings Goal Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSavingsGoal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/app_surface"
            app:layout_constraintTop_toBottomOf="@id/cardForecast">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Mục Tiêu Tích Lũy"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvChangeGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Đổi mục tiêu"
                        android:textColor="@color/app_accent_cyan"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:padding="4dp"/>
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvGoalName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mua điện thoại mới"
                    android:textColor="@color/app_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvGoalProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15,000,000đ / 20,000,000đ"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvGoalPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="75%"
                        android:textColor="@color/app_accent_income"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                </RelativeLayout>

                <ProgressBar
                    android:id="@+id/pbGoal"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="8dp"
                    android:progress="75"
                    android:progressTint="@color/app_accent_income"
                    android:progressBackgroundTint="@color/app_divider"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thời gian còn lại"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="11sp"/>
                        <TextView
                            android:id="@+id/tvRemainingDays"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45 ngày"
                            android:textColor="@color/app_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dự kiến hoàn thành"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="11sp"/>
                        <TextView
                            android:id="@+id/tvCompletionDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15/08/2026"
                            android:textColor="@color/app_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <RelativeLayout
            android:id="@+id/layoutRecommendationsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/cardSavingsGoal">

            <TextView
                android:id="@+id/tvRecommendationsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Khuyến Nghị Từ AI"
                android:textColor="@color/app_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvViewAllRecommendations"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:padding="8dp"
                android:text="Xem tất cả"
                android:textColor="@color/app_accent_income"
                android:textSize="14sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layoutRecommendations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/layoutRecommendationsHeader"/>

        <!-- Budget Recommendations -->
        <TextView
            android:id="@+id/tvBudgetRecLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đề Xuất Hạn Mức Ngân Sách"
            android:textColor="@color/app_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/layoutRecommendations"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/layoutSuggestedBudgets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvBudgetRecLabel"/>

        <Button
            android:id="@+id/btnApplyAll"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:text="Áp dụng tất cả đề xuất"
            android:textColor="@color/app_text_primary"
            android:backgroundTint="@color/app_accent_income"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/layoutSuggestedBudgets"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
