<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E2C"
    android:paddingLeft="24dp"
    android:paddingRight="24dp"
    android:paddingTop="48dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/tvBudgetsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ngân Sách Tháng"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnAiPlanner"
        android:layout_width="188dp"
        android:layout_height="39dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#8A2BE2"
        android:text="🤖 AI Smart Planner"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBudgetsTitle" />

    <LinearLayout
        android:id="@+id/layoutAddBudget"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnAiPlanner">

        <Spinner
            android:id="@+id/spinnerBudgetCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#2A2A3E"
            android:padding="8dp" />

        <EditText
            android:id="@+id/etBudgetAmount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="#2A2A3E"
            android:hint="Giới hạn ngân sách (đ)"
            android:inputType="number"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#808090" />

        <Button
            android:id="@+id/btnSaveBudget"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#00FF66"
            android:text="Thiết lập ngân sách"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvBudgetListLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:text="Tiến Độ Tiêu Dùng"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutAddBudget" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBudgetListLabel">

        <LinearLayout
            android:id="@+id/layoutBudgetsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

