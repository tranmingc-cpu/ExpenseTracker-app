<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E2C"
    android:paddingLeft="24dp"
    android:paddingRight="24dp"
    android:paddingTop="48dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/tvBudgetsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ngân Sách Tháng"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Form to set budget -->
    <LinearLayout
        android:id="@+id/layoutAddBudget"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvBudgetsTitle">

        <Spinner
            android:id="@+id/spinnerBudgetCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#2A2A3E"
            android:padding="8dp" />

        <EditText
            android:id="@+id/etBudgetAmount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#2A2A3E"
            android:hint="Giới hạn ngân sách (đ)"
            android:textColorHint="#808090"
            android:textColor="#FFFFFF"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:inputType="number"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnSaveBudget"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Thiết lập ngân sách"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00FF66"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvBudgetListLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tiến Độ Tiêu Dùng"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/layoutAddBudget"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- list  of budgets -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvBudgetListLabel"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/layoutBudgetsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
