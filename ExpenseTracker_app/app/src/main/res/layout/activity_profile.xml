<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E2C"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvProfileTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thông tin cá nhân"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etProfileName"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#2A2A3E"
        android:hint="Họ và tên"
        android:textColorHint="#808090"
        android:textColor="#FFFFFF"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:inputType="textPersonName"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvProfileTitle" />

    <EditText
        android:id="@+id/etProfilePhone"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#2A2A3E"
        android:hint="Số điện thoại"
        android:textColorHint="#808090"
        android:textColor="#FFFFFF"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:inputType="phone"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/etProfileName" />

    <Button
        android:id="@+id/btnUpdateProfile"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Cập nhật thông tin"
        android:textColor="#FFFFFF"
        android:backgroundTint="#00FF66"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/etProfilePhone" />

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2E2E4A"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnUpdateProfile" />

    <TextView
        android:id="@+id/tvSettingsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cài đặt bảo mật &amp; nhắc nhở"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- nhap ma Pin Code Configuration  -->
    <Button
        android:id="@+id/btnSetupPin"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Thiết lập/Đổi mã PIN mở khóa"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A4E"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSettingsTitle" />

    <Button
        android:id="@+id/btnRemovePin"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Xóa mã PIN bảo mật"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D32F2F"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnSetupPin" />

    <!-- Reminder Switch / Button -->
    <Button
        android:id="@+id/btnSetReminder"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Đặt giờ nhắc nhở ghi chép (9:00 tối)"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A4E"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnRemovePin" />

</androidx.constraintlayout.widget.ConstraintLayout>
