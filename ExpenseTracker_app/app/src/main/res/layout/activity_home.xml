<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#12121E"
    android:padding="16dp">

    <!-- Top Header -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xin chào,"
            android:textColor="#8A8A9E"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvDashboardUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvGreeting"
            android:text="Người Dùng"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@android:drawable/btn_default"
            android:backgroundTint="#2A2A3E"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_myplaces" />

    </RelativeLayout>

    <!-- Budget Warning Banner -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBudgetWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#D32F2F"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textSize="20sp"
                android:layout_marginRight="8dp" />

            <TextView
                android:id="@+id/tvBudgetWarningMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cảnh báo: Danh mục Ăn uống đã vượt ngân sách tháng!"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnDismissBudgetWarning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Balance / Net Income Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBalance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#1F1F35"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/cardBudgetWarning">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Số dư ròng (Net Income)"
                android:textColor="#8A8A9E"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvNetBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ₫"
                android:textColor="#00FF66"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2E2E4A"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng Thu Nhập"
                        android:textColor="#8A8A9E"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvTotalIncome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 ₫"
                        android:textColor="#00FF66"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng Chi Tiêu"
                        android:textColor="#8A8A9E"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvTotalExpense"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 ₫"
                        android:textColor="#FF3366"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Cash Income Quick Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardQuickIncome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#1F1F35"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/cardBalance">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etQuickIncomeAmount"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="#2A2A3E"
                android:hint="Bổ sung Tiền mặt (đ)"
                android:textColorHint="#808090"
                android:textColor="#FFFFFF"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:inputType="number"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btnSaveQuickIncome"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginLeft="8dp"
                android:text="Lưu"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00FF66"
                android:textSize="12sp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Navigation Hub (Grid of features) -->
    <GridLayout
        android:id="@+id/gridNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:columnCount="3"
        android:alignmentMode="alignMargins"
        app:layout_constraintTop_toBottomOf="@id/cardQuickIncome">

        <Button android:id="@+id/btnNavAdd" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Thêm GD" android:textColor="#FFFFFF" android:backgroundTint="#2A2A4E" android:textSize="11sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnNavBudgets" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Ngân Sách" android:textColor="#FFFFFF" android:backgroundTint="#2A2A4E" android:textSize="11sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnNavGoals" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Tiết Kiệm" android:textColor="#FFFFFF" android:backgroundTint="#2A2A4E" android:textSize="11sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnNavRecurring" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Định Kỳ" android:textColor="#FFFFFF" android:backgroundTint="#2A2A4E" android:textSize="11sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnNavSync" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Đồng Bộ" android:textColor="#FFFFFF" android:backgroundTint="#2A2A4E" android:textSize="11sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnNavExport" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Xuất CSV" android:textColor="#FFFFFF" android:backgroundTint="#2A2A4E" android:textSize="11sp" android:layout_margin="4dp"/>

    </GridLayout>

    <!-- Habit Alert Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardHabits"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#2A1B2E"
        app:layout_constraintTop_toBottomOf="@id/gridNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡"
                android:textSize="20sp"
                android:layout_marginRight="8dp" />

            <TextView
                android:id="@+id/tvHabitsWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chưa có cảnh báo tiêu dùng. Hãy ghi chép để AI phân tích thói quen."
                android:textColor="#FFBB00"
                android:textSize="12sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Transactions list / Summary section -->
    <TextView
        android:id="@+id/tvRecentLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Giao Dịch Gần Đây"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardHabits"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvRecentLabel"
        app:layout_constraintBottom_toTopOf="@id/btnSignOut">

        <LinearLayout
            android:id="@+id/layoutTransactionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <!-- Sign Out Button -->
    <Button
        android:id="@+id/btnSignOut"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:text="Đăng xuất"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D32F2F"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
