<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/app_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvRecTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Khuyến nghị"
            android:textColor="@color/app_accent_warning"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvRecDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Mô tả khuyến nghị"
            android:textColor="@color/app_text_primary"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvRecDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Giải thích từ AI..."
            android:textColor="@color/app_text_secondary"
            android:textSize="12sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnIgnore"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Bỏ qua"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btnAction"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="Áp dụng"
                android:textColor="@color/app_button_text"
                android:backgroundTint="@color/app_accent_income"
                android:textSize="12sp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
