<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kết Quả Phân Tích"
                android:textColor="@color/app_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dữ liệu bóc tách tự động từ hóa đơn / QR"
                android:textColor="@color/app_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/app_surface"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="16dp"
                            android:background="@color/app_accent_income"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="THÔNG TIN HÓA ĐƠN "
                            android:textColor="@color/app_accent_income"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngân hàng"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvQrBank"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Đang chờ quét..."
                        android:textColor="@color/app_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số tài khoản"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvQrAccountNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Đang chờ quét..."
                        android:textColor="@color/app_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên người nhận"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvQrRecipientName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Đang chờ quét..."
                        android:textColor="@color/app_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin giao dịch chi tiêu"
                android:textColor="@color/app_text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <EditText
                android:id="@+id/etQrAmount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edit_text"
                android:hint="Số tiền (đ)"
                android:textColorHint="#606075"
                android:textColor="@color/app_accent_income"
                android:textStyle="bold"
                android:textSize="18sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="number"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/etQrDescription"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edit_text"
                android:hint="Ghi chú / Nội dung"
                android:textColorHint="#606075"
                android:textColor="@color/app_text_primary"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="text"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Danh mục chi tiêu"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="16dp"
                android:layout_marginLeft="4dp"/>
            <Spinner
                android:id="@+id/spinnerQrCategory"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_spinner"
                android:padding="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ví / Tài khoản thanh toán"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="16dp"
                android:layout_marginLeft="4dp"/>
            <Spinner
                android:id="@+id/spinnerQrWallet"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_spinner"
                android:padding="8dp" />

            <Button
                android:id="@+id/btnSaveQrTransaction"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Lưu giao dịch chi tiêu"
                android:textColor="@color/app_background"
                android:background="@drawable/bg_button_primary"
                app:backgroundTint="@null"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="40dp" />

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/ocrProgressBar"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:visibility="gone"
        android:indeterminateTint="@color/app_accent_income"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>