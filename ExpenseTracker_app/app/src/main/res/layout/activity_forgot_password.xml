<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:padding="24dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="80sp"
                android:layout_marginTop="40dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quên mật khẩu"
                android:textColor="@color/app_text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhập email để nhận mã đặt lại có hiệu lực trong 10 phút"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <!-- Email Input -->
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@color/app_surface"
                android:hint="Nhập Email của bạn"
                android:textColorHint="@color/app_input_hint"
                android:textColor="@color/app_text_primary"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="textEmailAddress"
                android:layout_marginTop="32dp" />

            <!-- Send Request Button -->
            <Button
                android:id="@+id/btnSendCode"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Gửi mã xác thực"
                android:textColor="@color/app_button_text"
                android:backgroundTint="@color/app_accent_income"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <!--New Passowrd form  -->
            <LinearLayout
                android:id="@+id/layoutResetForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="24dp">

                <!-- Countdown Timer -->
                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thời gian còn lại: 10:00"
                    android:textColor="@color/app_accent_expense"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/etCode"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@color/app_surface"
                    android:hint="Nhập mã xác thực (6 chữ số)"
                    android:textColorHint="@color/app_input_hint"
                    android:textColor="@color/app_text_primary"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:inputType="number"
                    android:maxLength="6" />

                <Button
                    android:id="@+id/btnVerifyCode"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Xác nhận mã"
                    android:textColor="@color/app_text_primary"
                    android:backgroundTint="#5A5A8A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />

                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@color/app_surface"
                    android:hint="Nhập mật khẩu mới"
                    android:textColorHint="@color/app_input_hint"
                    android:textColor="@color/app_text_primary"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:inputType="textPassword"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tvPasswordRule"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mật khẩu phải có ít nhất 8 ký tự, gồm chữ hoa, chữ thường, số và ký tự đặc biệt."
                    android:textColor="#A8A8B8"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnResetPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Đặt lại mật khẩu"
                    android:textColor="@color/app_text_primary"
                    android:backgroundTint="@color/app_accent_income"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />

            </LinearLayout>

            <!-- Back to Login Link -->
            <TextView
                android:id="@+id/tvBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quay lại Đăng nhập"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="24dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:indeterminateTint="@color/app_accent_income"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
